# Flash / partition table
# The Matter + Tuya HTTP client + BME280 + esp_matter's bundled diagnostics
# components build to ~1.8MB, which doesn't fit ESP-IDF's default single-app
# partition table (1MB). Use this project's own partitions.csv (3MB factory
# partition) on a 4MB flash chip instead.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# mbedTLS (required by the Matter stack)
# Matter's crypto layer (CHIPCryptoPALmbedTLS.cpp) calls mbedtls_hkdf
# directly; mbedTLS ships it disabled by default.
CONFIG_MBEDTLS_HKDF_C=y

# Matter clusters: exclude Closure Control/Dimension (Matter 1.5, unused by
# this mini-split bridge). Their bundled connectedhomeip code fails to build
# with missing operator== on GenericOverallCurrentState/TargetState in both
# esp_matter 1.4.2 and 1.5.0 -- see espressif/esp-matter#1604. Excluding them
# avoids the bug entirely, regardless of esp_matter version.
CONFIG_SUPPORT_CLOSURE_CONTROL_CLUSTER=n
CONFIG_SUPPORT_CLOSURE_DIMENSION_CLUSTER=n

# Network transport: Thread, not WiFi. This device now joins the Matter
# fabric over Thread (via the OTBR running on the home server) instead of
# pre-connecting to WiFi with baked-in credentials -- the Thread Operational
# Dataset is handed to the device by the commissioner (Home Assistant, via
# OTBR) during BLE commissioning, the standard way Matter's Network
# Commissioning cluster works for Thread devices. See src/main.c for the
# corresponding boot-sequence change.
CONFIG_OPENTHREAD_ENABLED=y
CONFIG_ENABLE_MATTER_OVER_THREAD=y
# CONFIG_ENABLE_WIFI_STATION is not set

# Bluetooth (NimBLE only -- required for Matter/BLE commissioning, see
# BUILD.md "Bluetooth: NimBLE only" section). This was previously only ever
# set via manual menuconfig clicks in the original WiFi/BLE build and never
# captured here -- an `idf.py fullclean` regenerates sdkconfig from defaults
# only, and BT_ENABLED defaults to off on this target, so a fullclean
# silently produced a build with no Bluetooth at all. Confirmed on real
# hardware: `grep BT_ENABLED sdkconfig` came back "# CONFIG_BT_ENABLED is
# not set" after a fullclean rebuild, and the device never advertised BLE.
CONFIG_BT_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
# CONFIG_BT_BLUEDROID_ENABLED is not set

# BLE advertising must be told to autostart on power-up -- it defaults to 0
# (off) in connectedhomeip's Kconfig ("BLE Options" -> "Enable CHIPoBLE
# advertising start automatically after device power-up"). Without this,
# esp_matter::start() opens the commissioning window (QR code/setup code get
# printed, mDNS advertises over Thread) but never actually starts the BLE
# radio advertising, so the device is invisible to a BLE scan even though
# everything else looks like it's running fine. Found by direct hardware
# testing -- the device printed onboarding codes but never showed up in a
# BLE scan from the commissioning host.
CONFIG_CHIPOBLE_ENABLE_ADVERTISING_AUTOSTART=1
#
# Confirmed via real hardware: menuconfig resolved this to CONFIG_OPENTHREAD_FTD=y
# on its own (Full Thread Device -- correct for this mains-powered device).

# DNS64 client: without this, the device has no way to resolve an IPv4
# hostname (e.g. "pool.ntp.org" for SNTP, or Tuya's API hostname later) into
# a NAT64-synthesized address it can actually route to over Thread -- it can
# have perfectly working NAT44/masquerade border routing on the OTBR side
# and still fail every hostname-based connection. Confirmed missing on real
# hardware (sdkconfig showed "# CONFIG_OPENTHREAD_DNS64_CLIENT is not set")
# while chasing a repeated SNTP-timeout crash after Thread join succeeded.
CONFIG_OPENTHREAD_DNS64_CLIENT=y
